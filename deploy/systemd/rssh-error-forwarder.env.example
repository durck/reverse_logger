# Copy to /etc/reverse-logger/rssh-error-forwarder.env on the main host.

RSSH_ERROR_FORWARD_URL=http://127.0.0.1:8080/reverse-ssh-errors
RSSH_ERROR_FORWARD_TOKEN=edge_forward_token_from_main_env

# The systemd unit/journal source that emits reverse_ssh logs.
RSSH_JOURNAL_UNIT=reverse_ssh
RSSH_ERROR_SOURCE=journalctl

# Override for Docker-based deployments, for example:
# RSSH_JOURNAL_COMMAND=docker logs -f --since=0s reverse_ssh
RSSH_JOURNAL_COMMAND=journalctl -u 'reverse_ssh' -f -n 0 -o cat
RSSH_ERROR_FORWARD_TIMEOUT=5s
