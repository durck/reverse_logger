# Copy to /etc/reverse-logger/edge-logger.env on each VPS.

EDGE_LISTEN_ADDR=:443
EDGE_TARGET_ADDR=192.0.2.10:3232
EDGE_DATA_DIR=/var/lib/reverse-logger

VPS_NAME=vps-1
VPS_PUBLIC_IP=198.51.100.10
VPS_PUBLIC_PORT=443

# Optional: forward edge events into central rssh-logger.
# Disabled by default because the central logger is not exposed outside Docker
# unless docker-compose.edge-forward.yml is enabled on the main server.
EDGE_FORWARD_ENABLED=false
EDGE_FORWARD_URL=http://192.0.2.10:8080/edge-events
EDGE_FORWARD_TOKEN=edge_forward_token_from_main_env
EDGE_FORWARD_TIMEOUT=5s

# Public listener guardrails.
EDGE_DIAL_TIMEOUT=10s
EDGE_IDLE_TIMEOUT=10m
EDGE_MAX_CONNECTIONS=1024
EDGE_MAX_ACCEPTS_PER_SECOND=100
