# Copy to /etc/reverse-logger/nginx-edge-forwarder.env on each VPS.

NGINX_EDGE_LISTEN_ADDR=127.0.0.1:18080
NGINX_EDGE_CAPTURE_MODE=mirror

# Optional fallback tailer. Leave empty when nginx mirror capture is enabled.
NGINX_EDGE_LOG_PATH=
# Spool for short-lived ingress events before forward to main. The systemd unit
# creates this path via StateDirectory=; manual installs should mkdir -p it too.
NGINX_EDGE_SPOOL_DIR=/var/lib/reverse-logger/nginx-edge-spool
NGINX_EDGE_FORWARD_URL=http://192.0.2.10:8080/ingress-events
NGINX_EDGE_FORWARD_INTERVAL=1s
NGINX_EDGE_FORWARD_TIMEOUT=5s

EDGE_FORWARD_TOKEN=edge_forward_token_from_main_env

VPS_NAME=vps-1
VPS_PUBLIC_IP=198.51.100.10
# SoftEther/VPN address as seen by the main server (webhook ip_raw), not the VPS LAN IP.
VPS_INTERNAL_IP=192.0.2.2

# Keep aligned with nginx and, after patching reverse_ssh, server/client flags.
RSSH_WS_PATH=/ws
RSSH_PUSH_PATH=/push
