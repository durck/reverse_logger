# Copy to /etc/reverse-logger/edge-health.env on each VPS.

EDGE_HEALTH_FORWARD_URL=http://192.0.2.10:8080/edge-health
EDGE_HEALTH_TOKEN=edge_health_token_from_main_env
EDGE_HEALTH_INTERVAL=30s
EDGE_HEALTH_TIMEOUT=5s
EDGE_HEALTH_MISSED_REPORTS=3

EDGE_HEALTH_REVERSE_SSH_ADDR=192.0.2.10:3232
EDGE_HEALTH_LOGGER_HEALTH_URL=http://192.0.2.10:8080/healthz
# Leave empty to disable the VPN interface check.
EDGE_HEALTH_VPN_IFACE=vpn_softether
# Leave empty to disable local systemd service checks.
EDGE_HEALTH_SYSTEMD_SERVICES=nginx,nginx-edge-forwarder

VPS_NAME=vps-1
VPS_PUBLIC_IP=198.51.100.10
VPS_INTERNAL_IP=192.0.2.2
