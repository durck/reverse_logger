# Copy to /etc/nginx/sites-available/rssh-entrypoint.conf only for the first
# manual Let's Encrypt HTTP-01 issuance. Replace it with
# rssh-wss-https-entrypoint.conf.example after the certificate exists.

server {
    listen 80;
    server_name secret-entry.example.com;

    access_log /var/log/nginx/reverse_ssh_acme.log combined;

    location ^~ /.well-known/acme-challenge/ {
        root /var/www/letsencrypt;
        default_type text/plain;
        try_files $uri =404;
    }

    location / {
        return 301 https://example.com$request_uri;
    }
}
