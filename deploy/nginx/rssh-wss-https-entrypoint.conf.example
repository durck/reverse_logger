# Copy to /etc/nginx/sites-available/rssh-entrypoint.conf and adapt values.
# This template keeps reverse_ssh auth end-to-end: nginx terminates public TLS,
# but SSH host-key and client-key authentication remain inside WSS/HTTPS payloads.

map "$request_method:$uri:$http_upgrade:$arg_key" $rssh_transport {
    default "";
    "~^GET:/ws:[Ww][Ee][Bb][Ss][Oo][Cc][Kk][Ee][Tt]:.*$" "wss";
    "~^HEAD:/push::.+$" "https";
}

map $rssh_transport $rssh_loggable {
    default 0;
    wss 1;
    https 1;
}

map $http_upgrade $connection_upgrade {
    default upgrade;
    "" close;
}

log_format rssh_ingress escape=json
    '{"ts":"$time_iso8601",'
    '"request_id":"$request_id",'
    '"remote_addr":"$remote_addr",'
    '"remote_port":"$remote_port",'
    '"host":"$host",'
    '"request_method":"$request_method",'
    '"request_uri":"$request_uri",'
    '"uri":"$uri",'
    '"args":"$args",'
    '"status":$status,'
    '"http_upgrade":"$http_upgrade",'
    '"http_connection":"$http_connection",'
    '"http_user_agent":"$http_user_agent",'
    '"http_x_forwarded_for":"$http_x_forwarded_for",'
    '"server_addr":"$server_addr",'
    '"transport":"$rssh_transport"}';

server {
    listen 443 ssl;
    server_name secret-entry.example.com;

    ssl_certificate /etc/letsencrypt/live/secret-entry.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/secret-entry.example.com/privkey.pem;

    # Local diagnostic JSON log. The forwarder receives request-start metadata
    # through mirror below, because WebSocket access logs are emitted only after
    # the long-lived connection closes.
    access_log /var/log/nginx/reverse_ssh_ingress.json rssh_ingress if=$rssh_loggable;
    access_log /var/log/nginx/reverse_ssh_decoy.log combined;

    location = /_rssh_ingress_capture {
        internal;
        proxy_pass http://127.0.0.1:18080/capture;
        proxy_pass_request_body off;
        proxy_set_header Content-Length "";
        proxy_set_header X-RSSH-Transport $rssh_transport;
        proxy_set_header X-Request-ID $request_id;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Original-Remote-Addr $remote_addr;
        proxy_set_header X-Original-Remote-Port $remote_port;
        proxy_set_header X-Original-Host $host;
        proxy_set_header X-Original-Method $request_method;
        proxy_set_header X-Original-URI $request_uri;
        proxy_set_header X-Original-Path $uri;
        proxy_set_header X-Original-Args $args;
        proxy_set_header X-Original-Upgrade $http_upgrade;
        proxy_set_header X-Original-Connection $http_connection;
        proxy_set_header X-Original-User-Agent $http_user_agent;
        proxy_set_header X-Original-Server-Addr $server_addr;
    }

    # WSS transport. With patched reverse_ssh, replace /ws with the configured
    # --ws-path and update the map above to the same public path.
    location = /ws {
        if ($http_upgrade !~* "websocket") {
            return 404;
        }

        mirror /_rssh_ingress_capture;
        proxy_pass https://192.0.2.10:3232;
        proxy_ssl_verify off;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host $host;
        proxy_set_header X-Request-ID $request_id;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_buffering off;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }

    # HTTPS polling session init/write path. Only HEAD /push is logged as an
    # ingress event; POST /push is proxied but intentionally not edge-logged.
    location = /push {
        mirror /_rssh_ingress_capture;
        proxy_pass https://192.0.2.10:3232;
        proxy_ssl_verify off;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Request-ID $request_id;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_buffering off;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }

    # HTTPS polling read path. Do not edge-log this high-volume polling noise.
    location ^~ /push/ {
        proxy_pass https://192.0.2.10:3232;
        proxy_ssl_verify off;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Request-ID $request_id;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_buffering off;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }

    location / {
        return 301 https://example.com$request_uri;
    }
}
