# Managed by Ansible. Keep paths aligned with reverse_ssh server/client flags,
# nginx-edge-forwarder RSSH_* values, and central logger INGRESS_* values.

map "$request_method:$uri:$http_upgrade:$arg_key" $rssh_transport {
    default "";
    "~^GET:{{ rssh_ws_path | regex_escape }}:[Ww][Ee][Bb][Ss][Oo][Cc][Kk][Ee][Tt]:.*$" "wss";
    "~^HEAD:{{ rssh_push_path | regex_escape }}::.+$" "https";
}

map $rssh_transport $rssh_loggable {
    default 0;
    wss 1;
    https 1;
}

map $http_upgrade $connection_upgrade {
    default upgrade;
    "" close;
}

log_format rssh_ingress escape=json
    '{"ts":"$time_iso8601",'
    '"request_id":"$request_id",'
    '"remote_addr":"$remote_addr",'
    '"remote_port":"$remote_port",'
    '"host":"$host",'
    '"request_method":"$request_method",'
    '"request_uri":"$request_uri",'
    '"uri":"$uri",'
    '"args":"$args",'
    '"status":$status,'
    '"http_upgrade":"$http_upgrade",'
    '"http_connection":"$http_connection",'
    '"http_user_agent":"$http_user_agent",'
    '"http_x_forwarded_for":"$http_x_forwarded_for",'
    '"server_addr":"$server_addr",'
    '"transport":"$rssh_transport"}';

server {
    listen 80;
    server_name {{ rssh_domain }};

    access_log /var/log/nginx/reverse_ssh_acme.log combined;

    location ^~ /.well-known/acme-challenge/ {
        root {{ nginx_edge_acme_webroot }};
        default_type text/plain;
        try_files $uri =404;
    }

    location / {
        return 301 {{ redirect_target }}$request_uri;
    }
}

server {
    listen 443 ssl;
    server_name {{ rssh_domain }};

    ssl_certificate {{ tls_cert_path }};
    ssl_certificate_key {{ tls_key_path }};

    access_log /var/log/nginx/reverse_ssh_ingress.json rssh_ingress if=$rssh_loggable;
    access_log /var/log/nginx/reverse_ssh_decoy.log combined;

    location = /_rssh_ingress_capture {
        internal;
        proxy_pass http://{{ nginx_edge_listen_addr }}/capture;
        proxy_pass_request_body off;
        proxy_set_header Content-Length "";
        proxy_set_header X-RSSH-Transport $rssh_transport;
        proxy_set_header X-Request-ID $request_id;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Original-Remote-Addr $remote_addr;
        proxy_set_header X-Original-Remote-Port $remote_port;
        proxy_set_header X-Original-Host $host;
        proxy_set_header X-Original-Method $request_method;
        proxy_set_header X-Original-URI $request_uri;
        proxy_set_header X-Original-Path $uri;
        proxy_set_header X-Original-Args $args;
        proxy_set_header X-Original-Upgrade $http_upgrade;
        proxy_set_header X-Original-Connection $http_connection;
        proxy_set_header X-Original-User-Agent $http_user_agent;
        proxy_set_header X-Original-Server-Addr $server_addr;
    }

    location = {{ rssh_ws_path }} {
        if ($http_upgrade !~* "websocket") {
            return 404;
        }

        mirror /_rssh_ingress_capture;
        proxy_pass {{ backend_reverse_ssh_url }};
        proxy_ssl_verify off;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host $host;
        proxy_set_header X-Request-ID $request_id;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_buffering off;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }

    location = {{ rssh_push_path }} {
        mirror /_rssh_ingress_capture;
        proxy_pass {{ backend_reverse_ssh_url }};
        proxy_ssl_verify off;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Request-ID $request_id;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_buffering off;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }

    location ^~ {{ rssh_push_path }}/ {
        proxy_pass {{ backend_reverse_ssh_url }};
        proxy_ssl_verify off;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Request-ID $request_id;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_buffering off;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }

    location / {
        return 301 {{ redirect_target }}$request_uri;
    }
}
