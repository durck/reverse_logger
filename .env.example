# Copy to .env and fill values manually. Do not commit .env.

# Main server private/internal address that Docker binds reverse_ssh to.
# The VPS reaches this address through the SoftEther path.
REVERSE_SSH_BIND_IP=192.0.2.10
REVERSE_SSH_BIND_PORT=3232

# Public VPS entrypoint port. VPS DNAT uses this value when exported as
# REVERSE_SSH_PUBLIC_PORT, or the same value can be passed as PUBLIC_PORT.
# The VPS forwards this public port to REVERSE_SSH_BIND_IP:REVERSE_SSH_BIND_PORT.
REVERSE_SSH_PUBLIC_PORT=443

# Local reverse_ssh image built by deploy/docker/build-reverse-ssh-image.sh.
REVERSE_SSH_IMAGE=reverse-ssh:local

# Optional: let the helper clone reverse_ssh. Leave empty if cloning manually.
REVERSE_SSH_REPO_URL=
REVERSE_SSH_REPO_REF=
REVERSE_SSH_SOURCE_DIR=/opt/reverse-logger/src/reverse_ssh
REVERSE_SSH_BUILD_CONTEXT=/opt/reverse-logger/src/reverse_ssh
REVERSE_SSH_DOCKERFILE=/opt/reverse-logger/src/reverse_ssh/Dockerfile

# Address embedded into generated clients for this entrypoint.
REVERSE_SSH_EXTERNAL_ADDRESS=vps-entrypoint.example.com:443

# reverse_ssh listener web transport paths. Keep these aligned with nginx,
# nginx-edge-forwarder, central INGRESS_* values, and generated clients.
REVERSE_SSH_WS_PATH=/ws
REVERSE_SSH_PUSH_PATH=/push

# Optional: trust real-IP headers only from the nginx/VPN source CIDR.
# Example: 192.0.2.2/32
REVERSE_SSH_TRUSTED_PROXY_CIDR=

# Paste the reverse_ssh operator public key contents, not a file path.
# Generate one with:
#   ssh-keygen -t ed25519 -a 100 -f ~/.ssh/reverse_ssh_operator -C "reverse_ssh_operator"
#   cat ~/.ssh/reverse_ssh_operator.pub
SEED_AUTHORIZED_KEYS="ssh-ed25519 <public-key> operator@example.com"

# Persistent data paths on the main server.
REVERSE_SSH_DATA_DIR=/opt/reverse-logger/data/reverse_ssh
LOGGER_DATA_DIR=/opt/reverse-logger/data/logger

# rssh-logger webhook secret path token.
WEBHOOK_TOKEN=replace_with_long_random_token

# Optional central endpoint for VPS edge-logger forwarded edge events.
EDGE_FORWARD_TOKEN=replace_with_second_long_random_token

# Central validation for nginx ingress events. Keep aligned with VPS nginx and
# nginx-edge-forwarder RSSH_* paths.
INGRESS_WS_PATH=/ws
INGRESS_PUSH_PATH=/push

# Optional host binding for central edge event forwarding.
# This is used only with docker-compose.edge-forward.yml.
LOGGER_BIND_PORT=8080

# Telegram alerts. Keep the bot token only in .env on the main server.
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=telegram_bot_token
TELEGRAM_CHAT_IDS=telegram_chat_id

# VPS HTTP/SOCKS proxy used by the main server to reach Telegram.
# Examples:
#   http://proxy-user:proxy-pass@proxy.example.com:3128
#   socks5://proxy-user:proxy-pass@proxy.example.com:1080
TELEGRAM_PROXY_URL=

# Keep local service names and internal addresses out of the proxy.
NO_PROXY=localhost,127.0.0.1,rssh-logger,reverse_ssh,192.0.2.0/24
